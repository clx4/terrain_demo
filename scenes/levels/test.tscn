[sub_resource type="Shader" id="Shader_u81e1"]
code = "shader_type spatial;
render_mode ambient_light_disabled, blend_mix, depth_draw_opaque, cull_back;
#include \"res://assets/shaders/shaderincs/cel_shader.gdshaderinc\"

group_uniforms Material;
uniform vec4      albedo_color : source_color = vec4(1.0);
uniform sampler2D albedo_tex   : source_color, filter_linear_mipmap, repeat_enable;
uniform vec2      uv_scale     = vec2(1.0);
uniform vec2      uv_offset    = vec2(0.0);
group_uniforms;

varying vec3  world_normal;
varying vec3  world_pos;
varying float line_mask;

void vertex() {
    world_normal = toon_vertex(MODEL_NORMAL_MATRIX, NORMAL);
    world_pos    = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
}

void fragment() {
    vec2 uv = UV * uv_scale + uv_offset;

    vec3 toon_albedo;
    vec3 toon_emission;
    toon_fragment(toon_albedo, toon_emission);

    vec3 tex = texture(albedo_tex, uv).rgb * albedo_color.rgb;
    ALBEDO   = tex * toon_albedo;
    EMISSION = toon_emission * tex;
}

void light() {
    if (line_mask > 0.25) {
        float ndotl    = max(0.0, dot(NORMAL, LIGHT));
        DIFFUSE_LIGHT += LIGHT_COLOR * ATTENUATION * ndotl;
        SPECULAR_LIGHT = vec3(0.0);
    } else {
        float lit_amount;
        toon_light(
            NORMAL,
            LIGHT,
            VIEW,
            LIGHT_COLOR,
            ATTENUATION,
            LIGHT_IS_DIRECTIONAL,
            world_pos,
            INV_VIEW_MATRIX[0].xyz,
            INV_VIEW_MATRIX[1].xyz,
            DIFFUSE_LIGHT,
            SPECULAR_LIGHT,
            lit_amount
        );
    }
}"

